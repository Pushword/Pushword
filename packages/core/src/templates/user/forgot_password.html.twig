{% extends view('/user/layout.html.twig') %}

{% block title %}{{ 'forgotPasswordTitle'|trans }}{% endblock %}

{% block main_content %}
{% if email_sent %}
  <div class="flex items-center gap-3 p-5 mb-4 text-green-800 bg-green-100 rounded" role="status">
    <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
    <span>{{ 'forgotPasswordEmailSent'|trans }}</span>
  </div>
  <a href="{{ path('pushword_login') }}" class="text-sm text-primary hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">{{ 'backToLogin'|trans }}</a>
{% else %}

{% for message in app.flashes('error') %}
  <div role="alert" class="flex items-center gap-3 p-5 mb-4 text-red-800 bg-red-50 rounded">
    <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/></svg>
    <span>{{ message|trans }}</span>
  </div>
{% endfor %}

<form method="post" action="{{ path('pushword_forgot_password') }}" class="mt-8 space-y-6">
  <label for="inputEmail" class="sr-only">{{ 'securityLoginEmail'|trans }}</label>
  <input type="email" id="inputEmail" name="email" required autofocus
         class="block w-full px-3 py-2 text-gray-900 placeholder-gray-500 border border-gray-300 rounded-md shadow-xs sm:text-sm focus:outline-hidden focus:ring-primary focus:border-primary"
         placeholder="{{ 'securityLoginEmail'|trans }}">

  <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">

  <button type="submit" class="relative flex justify-center w-full px-4 py-2 text-sm font-medium text-white border border-transparent rounded-md bg-primary group hover:opacity-75 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-primary">
    {{ 'forgotPasswordButton'|trans }}
  </button>
</form>

<div class="mt-4 text-center">
  <a href="{{ path('pushword_login') }}" class="text-sm text-primary hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">{{ 'backToLogin'|trans }}</a>
</div>
{% endif %}
{% endblock %}
