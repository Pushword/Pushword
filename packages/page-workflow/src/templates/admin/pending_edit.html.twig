<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ 'adminPagePendingEditTitle'|trans }}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
<div class="container py-4">
  <h1 class="h3 mb-1">{{ 'adminPagePendingEditTitle'|trans }}</h1>
  <code class="mb-3 d-block">/{{ page.slug }}</code>
  <p class="text-muted">{{ 'adminPagePendingEditHelp'|trans }}</p>

  <form method="POST" class="card shadow-sm">
    <input type="hidden" name="_token" value="{{ csrf_token(csrfTokenId) }}">
    <div class="card-body">
      {% for field in fields %}
        <div class="mb-3">
          <label class="form-label fw-bold" for="pending_{{ field }}">{{ field }}</label>
          {% if field == 'mainContent' %}
            <textarea class="form-control" id="pending_{{ field }}" name="{{ field }}" rows="14">{{ modification.payload[field]|default('') }}</textarea>
          {% else %}
            <input class="form-control" id="pending_{{ field }}" name="{{ field }}" value="{{ modification.payload[field]|default('') }}">
          {% endif %}
        </div>
      {% endfor %}

      <div class="mb-3">
        <label class="form-label fw-bold" for="pending_editMessage">{{ 'adminPagePendingEditMessageLabel'|trans }}</label>
        <input class="form-control" id="pending_editMessage" name="editMessage" value="{{ modification.editMessage }}">
      </div>
    </div>

    <div class="card-footer d-flex gap-2">
      <button type="submit" class="btn btn-primary">{{ 'adminPagePendingSave'|trans }}</button>
      <a href="/admin" class="btn btn-secondary">{{ 'adminPagePendingCancel'|trans }}</a>
    </div>
  </form>
</div>
</body>
</html>
