{# Custom action template for workflow transitions: renders a POST <form> with
   CSRF token instead of a GET link, so transitions are CSRF-protected.
   Included by EasyAdmin's crud/edit.html.twig with {action, entity}, with_context: false. #}
{% set tokenId = action.htmlAttributes['data-pw-csrf-token-id']|default('') %}
{% set variant = action.variant.value is defined ? action.variant.value : action.variant %}
{% set variantClass = variant == 'default' ? 'btn-secondary' : 'btn-' ~ variant %}
<form action="{{ action.linkUrl }}" method="POST" class="d-inline">
  <input type="hidden" name="_token" value="{{ csrf_token(tokenId) }}">
  <button type="submit" class="btn {{ variantClass }} {{ action.cssClass }}">
    {%- set actionLabel = action.label|trans -%}
    {%- if actionLabel is not empty -%}<span class="action-label">{{ actionLabel|raw }}</span>{%- endif -%}
  </button>
</form>
