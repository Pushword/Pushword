{% if page.id is not null and transitions is not empty %}
  <div class="pw-workflow-transitions d-flex flex-wrap gap-2 mt-2">
    {% for transition in transitions %}
      <button
        type="button"
        class="btn btn-sm btn-outline-primary pw-workflow-transition"
        data-action="{{ path('pushword_page_workflow', {id: page.id, transition: transition}) }}"
        data-token="{{ csrf_token('workflow-' ~ page.id) }}"
      >
        {{ ('adminPageWorkflowTransition.' ~ transition)|trans }}
      </button>
    {% endfor %}
  </div>

  <script>
  (function() {
    'use strict';
    document.querySelectorAll('.pw-workflow-transition').forEach(function(btn) {
      btn.addEventListener('click', function() {
        btn.disabled = true;
        var body = new URLSearchParams({ _token: btn.dataset.token });
        fetch(btn.dataset.action, { method: 'POST', body: body })
          .then(function() { window.location.reload(); })
          .catch(function() { btn.disabled = false; });
      });
    });
  })();
  </script>
{% endif %}
