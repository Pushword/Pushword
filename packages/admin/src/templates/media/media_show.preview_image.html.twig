<div class="row">
    <div class="col-md-6" style="margin-bottom: 15px;">
        <a href="{{ media|image('default') }}" target="_blank" rel="noopener noreferrer" style="display: block; position:relative">
            <span class="mosaic-box-label label label-default" style="position: absolute; left: 10px; right: unset">{{ media.ratioLabel }}</span>
            <img src="{{ media|image('md', checkFileExists: true) }}?{{ random() }}"
                 alt="{{ media.alt|e }}"
                 class="img-responsive img-thumbnail"
                 style="max-width: 100%; height: auto;">
        </a>
        {% if rotate_left_url is defined %}
        <div class="d-flex gap-2 justify-content-center" style="margin-top: 8px;">
            <a href="{{ rotate_left_url }}" class="btn btn-sm btn-outline-secondary" title="{{ 'adminMediaRotateLeftLabel'|trans }}" aria-label="{{ 'adminMediaRotateLeftLabel'|trans }}"><i class="fa fa-rotate-left" aria-hidden="true"></i></a>
            <a href="{{ rotate_right_url }}" class="btn btn-sm btn-outline-secondary" title="{{ 'adminMediaRotateRightLabel'|trans }}" aria-label="{{ 'adminMediaRotateRightLabel'|trans }}"><i class="fa fa-rotate-right" aria-hidden="true"></i></a>
        </div>
        {% endif %}
    </div>
    <div class="col-md-6">
        <div style="margin-bottom: 15px;">
            <strong>{{ 'adminMediaPreviewPath'|trans }}</strong>
            <code style="display: block; margin-top: 5px; padding: 8px; background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 4px;">{{ media.fileName }}</code>
        </div>

        <div style="margin-bottom: 15px;">
            <strong>{{ 'adminMediaPreviewMarkdown'|trans }}</strong>
            <pre style="margin-top: 5px; padding: 8px; background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 4px;"><code>![{{ media.alt|replace({'[': '', ']': ''}) }}]({{ media.fileName }})</code></pre>
        </div>

        <div style="margin-bottom: 15px;">
            <strong>{{ 'adminMediaPreviewJson'|trans }}</strong>
            <pre style="margin-top: 5px; padding: 8px; background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 4px;"><code>{
  "{{ media.fileName }}": "{{ media.alt|replace({'"': '\\"',}) }}"
}</code></pre>
        </div>

        {% if media.getMainColor %}
        <div style="margin-bottom: 15px;">
            <strong>{{ 'adminMediaPreviewDominantColor'|trans }}</strong>
            <pre style="margin-top: 5px; padding: 8px; border: 1px solid #ddd; border-radius: 4px; background-color: {{ media.getMainColor }}; color: {{ media.mainColorOpposite }};">{{ media.getMainColor }}</pre>
        </div>
        {% endif %}

        {% if media.fileNameHistory is not empty %}
        <div style="margin-bottom: 15px;">
            <strong>{{ 'adminMediaPreviewHistory'|trans }}</strong>
            <ul style="margin-top: 5px; padding: 8px 8px 8px 28px; background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 4px; list-style: disc;">
              {% for oldName in media.fileNameHistory %}
                <li><code>{{ oldName }}</code></li>
              {% endfor %}
            </ul>
        </div>
        {% endif %}
    </div>
</div>
