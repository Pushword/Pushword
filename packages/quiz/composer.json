{
    "name": "pushword/quiz",
    "type": "symfony-bundle",
    "description": "Interactive client-side quizzes (QCM) for Pushword: a {{ quiz(...) }} Twig block, an EditorJS editor, anonymous percentile stats and an optional end-of-quiz conversion form.",
    "keywords": [],
    "homepage": "https://pushword.piedweb.com/extension/quiz",
    "license": "MIT",
    "require": {
        "pushword/core": "*"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "autoload": {
        "psr-4": {
            "Pushword\\Quiz\\": "src"
        }
    },
    "authors": [
        {
            "name": "Robin@PiedWeb",
            "email": "contact@piedweb.com",
            "homepage": "https://piedweb.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
