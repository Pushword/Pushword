{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{{ 'template_editorDeleteTitle'|trans }}{% endblock %}

{% block page_actions %}
    <a class="btn btn-outline-secondary" href="{{ path('admin_template_editor_list') }}">
        <i class="fa fa-arrow-left me-2" aria-hidden="true"></i> {{ 'template_editorBackToList'|trans }}
    </a>
{% endblock %}

{% block main %}
    {% if message is defined %}
        <div class="alert alert-success" role="alert">
            {{ message|trans }}
        </div>
    {% else %}
        {{ form_start(form) }}
        <div class="card border-danger">
            <div class="card-header text-danger fw-bold">
                {{ 'template_editorDeleteConfirmTitle'|trans }}
            </div>
            <div class="card-body">
                <p class="mb-0">
                    {{ 'template_editorDeleteConfirm'|trans({'%path%': element.path}) }}
                </p>
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                {{ form_widget(form) }}
            </div>
        </div>
        {{ form_end(form) }}
    {% endif %}
{% endblock %}
