{% block right_column %}
{% if page.slug != 'homepage' %}
{% set heading_class = 'block mt-6 mb-2 text-[11px] font-semibold tracking-wider text-stone-500 dark:text-stone-400 uppercase' %}
{% set link_class = 'block py-1.5 pl-4 -ml-px border-l border-transparent text-stone-700 hover:text-stone-900 hover:border-stone-400 dark:text-stone-300 dark:hover:text-stone-100' %}
{% set active_class = 'block py-1.5 pl-4 -ml-px border-l border-[oklch(45%_0.13_35)] text-[oklch(45%_0.13_35)] dark:text-[oklch(70%_0.13_35)] dark:border-[oklch(70%_0.13_35)] font-medium' %}

<details class="group lg:open:" open>
  <summary class="lg:hidden flex items-center gap-2 px-4 py-3 text-sm font-medium text-stone-700 border-b border-stone-200 cursor-pointer select-none dark:text-stone-300 dark:border-stone-800 [&::-webkit-details-marker]:hidden" aria-controls="docs-nav">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    Documentation
  </summary>

  <nav id="docs-nav" aria-label="Documentation" class="lg:sticky lg:top-20 px-4 py-6 text-sm lg:max-h-[calc(100vh-5rem)] lg:overflow-y-auto">
    {% for n in nav %}
      {% set uri = n.1 == '#' ? '#' : page(n.1) %}
      {% if n.2 is defined %}
        <span class="{{ heading_class }}">{{ n.0 }}</span>
      {% else %}
        <a href="{{ uri }}" class="{{ is_current_page(uri, page) ? active_class : link_class }}">{{ n.0 }}</a>
      {% endif %}
    {% endfor %}

    <a href="https://github.com/Pushword/Pushword" class="{{ link_class }} mt-6 flex items-center gap-2">
      {{ svg('github', {class: 'w-3.5 h-3.5'}) }}
      <span>Source on GitHub</span>
    </a>
  </nav>
</details>
{% endif %}
{% endblock %}
