{% extends '@Pushword/page/page_default.html.twig' %}

{% set nav = [
    ['Get Started', 'installation', true],
    ['Introduction', ''],
    ['Installation', 'installation'],
    ['Configuration', 'configuration'],
    ['Upgrade Guide', 'upgrade'],
    ['Usage', 'command', true],
    ['Frontend', 'themes'],
    ['Extensions', 'extensions'],
    ['Command', 'command'],
    ['Editor (markdown)', 'editor'],
    ['List Pages', 'pages-list'],
    ['Batch & Bulk ', 'bulk-edition'],
    ['Developper', 'create-extension', true],
    ['Create an extension', 'create-extension'],
    ['Entity Filter', 'component/entity-filter'],
    ['Contribute', 'contribute', true],
    ['Issues and Pull Request', 'contribute'],
    ['Development environment.', 'architecture', true],
    ['Roadmap', 'roadmap'],
    ['Support', 'pro'],
] %}
{#
    ['Image', 'component/image'],
#}
{% set breadcrumb_class = 'p-3 text-sm font-light text-gray-700 dark:text-gray-300' %}

{% block open_graph %}
  <script>
    const base = "{{ page('homepage') }}"
  </script>
  {{ parent() }}
{% endblock %}

{% block html_opener %}
<html lang="{{ page.locale|default(apps.get().locale) }}" {{ mergeAttr({class: 'leading-relaxed text-stone-900 bg-stone-50 dark:bg-stone-950 dark:text-stone-100'}, page.htmlOpenerAttr|default({})) }}>
{% endblock %}

{% block content %}
<div class="mx-auto max-w-(--breakpoint-xl) min-h-[80vh] grid grid-cols-1 lg:grid-cols-[16rem_minmax(0,1fr)]">

    <aside class="lg:border-r lg:border-stone-200 lg:dark:border-stone-800">
        {{ include(view('/page/_right_column.html.twig')) }}
    </aside>

    <div class="min-w-0">
        {{ include(view('/page/_breadcrumb.html.twig')) }}
        {{ include(view('/page/_content.html.twig')) }}
    </div>

</div>
{% endblock %}

{% block breadcrumb %} {% endblock %}
