{
  "name": "pushword/dev-app",
  "type": "symfony-bundle",
  "description": "Pushword dev/test/demo application. Used for testing, demoing and by the installer. It's not a copy-paste starter, prefer the installer (see https://pushword.piedweb.com/installation ).",
  "keywords": [],
  "homepage": "https://pushword.piedweb.com",
  "license": "MIT",
  "require": {
    "pushword/core": "*"
  },
  "require-dev": {},
  "extra": {
    "branch-alias": {
      "dev-main": "1.0.x-dev"
    }
  },
  "autoload": {},
  "autoload-dev": {},
  "authors": [
    {
      "name": "Robin@PiedWeb",
      "email": "contact@piedweb.com",
      "homepage": "https://piedweb.com"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    }
  }
}
